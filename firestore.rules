rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function incomingData() {
      return request.resource.data;
    }

    function isPositiveNumber(val) {
      return val is number && val >= 0;
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    // Only the owner can read or write their own profile. Cross-user reads
    // (leaderboard, search, social) have been removed from the app.
    // Admin user listing requires Firebase Admin SDK (server-side) — not Firestore rules.
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && incomingData().uid == uid
        && incomingData().keys().hasAll(["uid", "displayName", "email",
                                         "totalSaved", "totalSkips", "streak"])
        && isPositiveNumber(incomingData().totalSaved)
        && isPositiveNumber(incomingData().totalSkips)
        && isPositiveNumber(incomingData().streak);
      allow update: if isOwner(uid)
        // uid is immutable
        && (!incomingData().keys().hasAny(["uid"]) || incomingData().uid == uid)
        // Interim financial guard: counters can only increase, capped per write.
        // Root fix: move writes to Cloud Functions. These rules prevent the worst
        // abuse (setting totalSaved=99999) without breaking the current client architecture.
        && (!incomingData().diff(resource.data).affectedKeys().hasAny(["totalSaved"])
            || (incomingData().totalSaved is number
                && incomingData().totalSaved >= resource.data.get("totalSaved", 0)
                && incomingData().totalSaved - resource.data.get("totalSaved", 0) <= 10000))
        && (!incomingData().diff(resource.data).affectedKeys().hasAny(["totalSkips"])
            || (incomingData().totalSkips is number
                && incomingData().totalSkips >= resource.data.get("totalSkips", 0)
                && incomingData().totalSkips - resource.data.get("totalSkips", 0) <= 100))
        && (!incomingData().diff(resource.data).affectedKeys().hasAny(["totalDonated"])
            || (incomingData().totalDonated is number
                && incomingData().totalDonated >= resource.data.get("totalDonated", 0)
                && incomingData().totalDonated - resource.data.get("totalDonated", 0) <= 10000))
        && (!incomingData().diff(resource.data).affectedKeys().hasAny(["totalGiveAllocated"])
            || (incomingData().totalGiveAllocated is number
                && incomingData().totalGiveAllocated >= resource.data.get("totalGiveAllocated", 0)
                && incomingData().totalGiveAllocated - resource.data.get("totalGiveAllocated", 0) <= 10000))
        // totalLiveAllocated can decrease (skip deletes, transfer-to-give) but cap increases at 10000/write
        && (!incomingData().diff(resource.data).affectedKeys().hasAny(["totalLiveAllocated"])
            || (incomingData().totalLiveAllocated is number
                && incomingData().totalLiveAllocated - resource.data.get("totalLiveAllocated", 0) <= 10000));
      allow delete: if false;

      // ─── Skips ──────────────────────────────────────────────────────────
      match /skips/{skipId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
          && incomingData().uid == uid
          && incomingData().amount is number
          && incomingData().amount > 0
          && incomingData().category is string;
        allow update: if isOwner(uid)
          && (!incomingData().keys().hasAny(["uid"]) || incomingData().uid == uid);
        allow delete: if isOwner(uid);
      }

      // ─── Donations ──────────────────────────────────────────────────────
      match /donations/{donationId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
          && incomingData().amount is number
          && incomingData().amount > 0
          && incomingData().causeId is string
          && incomingData().causeTitle is string;
        allow update: if isOwner(uid)
          && incomingData().amount is number
          && incomingData().amount > 0;
        allow delete: if isOwner(uid);
      }

      // ─── Spending History ────────────────────────────────────────────────
      match /spendingHistory/{eventId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
          && incomingData().label is string
          && incomingData().amountSaved is number
          && incomingData().amountSaved > 0;
        allow update: if isOwner(uid)
          && incomingData().amountSaved is number
          && incomingData().amountSaved > 0;
        allow delete: if isOwner(uid);
      }

      // ─── Social Graph ────────────────────────────────────────────────────
      match /following/{targetUid} {
        // A user can see their own follow list; the followed user can verify
        // they're in the list for follower counts.
        allow read:   if isOwner(uid) || isOwner(targetUid);
        allow create: if isOwner(uid)
          && incomingData().uid == targetUid;
        allow delete: if isOwner(uid);
        allow update: if false;
      }
    }

    // ─── Projects (Causes) ──────────────────────────────────────────────────
    // Anyone signed in can browse causes. Custom causes can only be edited /
    // deleted by the user who created them; built-in causes are read-only.
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && incomingData().isCustom == true
        && incomingData().createdBy == request.auth.uid
        && incomingData().title is string
        && incomingData().title.size() > 0;
      allow update: if isSignedIn()
        && (
          // Owner can edit their custom cause
          (resource.data.isCustom == true && resource.data.createdBy == request.auth.uid)
          ||
          // Any authenticated user can update totalRaised (increment on skip, decrement on cause switch/delete)
          // Delta capped at ±5000 per write to prevent arbitrary value injection
          (
            incomingData().diff(resource.data).affectedKeys().hasOnly(["totalRaised"])
            && incomingData().totalRaised is number
            && incomingData().totalRaised >= 0
            && (incomingData().totalRaised - resource.data.totalRaised) <= 5000
            && (resource.data.totalRaised - incomingData().totalRaised) <= 5000
          )
          ||
          // Any authenticated user can add only themselves to memberUids (join)
          (
            incomingData().diff(resource.data).affectedKeys().hasOnly(["memberUids"])
            && incomingData().memberUids is list
            && incomingData().memberUids.hasAll(resource.data.get("memberUids", []))
            && incomingData().memberUids.removeAll(resource.data.get("memberUids", [])).hasOnly([request.auth.uid])
            && incomingData().memberUids.size() == resource.data.get("memberUids", []).size() + 1
          )
          ||
          // Any authenticated user can remove only themselves from memberUids (leave)
          (
            incomingData().diff(resource.data).affectedKeys().hasOnly(["memberUids"])
            && incomingData().memberUids is list
            && resource.data.get("memberUids", []).hasAll(incomingData().memberUids)
            && resource.data.get("memberUids", []).removeAll(incomingData().memberUids).hasOnly([request.auth.uid])
            && incomingData().memberUids.size() == resource.data.get("memberUids", []).size() - 1
          )
        );
      allow delete: if isSignedIn()
        && resource.data.isCustom == true
        && resource.data.createdBy == request.auth.uid;
    }

    // ─── Personal Fan-out Feed ───────────────────────────────────────────────
    // The feed owner reads their own feed. The owner also writes (feed items
    // are created client-side in the same batch as the skip document).
    match /feed/{uid}/items/{itemId} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid) && incomingData().uid == uid;
      allow update: if isOwner(uid) && incomingData().uid == uid;
      allow delete: if isOwner(uid);
    }

    // ─── Community Feed ──────────────────────────────────────────────────────
    // All signed-in users can read. A user can create a feed item if the doc ID
    // matches their skip (document ID = skipId, uid field = caller). They can
    // only delete or update their own items.
    match /communityFeed/{skipId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
        && incomingData().uid == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && incomingData().uid == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.uid == request.auth.uid;
    }

    // ─── Deny everything else ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
