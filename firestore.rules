rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function incomingData() {
      return request.resource.data;
    }

    function isPositiveNumber(val) {
      return val is number && val >= 0;
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    // Only the owner can read or write their own profile. Cross-user reads
    // (leaderboard, search, social) have been removed from the app.
    // Admin user listing requires Firebase Admin SDK (server-side) — not Firestore rules.
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && incomingData().uid == uid
        && incomingData().keys().hasAll(["uid", "displayName", "email",
                                         "totalSaved", "totalSkips", "streak"])
        && isPositiveNumber(incomingData().totalSaved)
        && isPositiveNumber(incomingData().totalSkips)
        && isPositiveNumber(incomingData().streak)
        // referredBy/referralCount/pushOptIn/fcmTokens are set exclusively by server routes
        // (Admin SDK, bypasses these rules) — never by the client's initial write.
        && !incomingData().keys().hasAny(["referredBy", "referralCount", "pushOptIn", "fcmTokens"]);
      allow update: if isOwner(uid)
        // uid is immutable
        && (!incomingData().keys().hasAny(["uid"]) || incomingData().uid == uid)
        // Money/derived/referral fields are exclusively server-computed (Admin SDK writes
        // bypass these rules). Clients may no longer touch them directly — this keeps
        // referredBy immutable and self-referral-proof once attributed.
        && !incomingData().diff(resource.data).affectedKeys().hasAny([
             "totalSaved", "totalSkips", "totalDonated", "totalSpent",
             "totalGiveAllocated", "totalLiveAllocated", "savedTowardActiveCause",
             "xp", "level", "streak", "longestStreak", "lastSkipDate",
             "causeJarBalances", "goalJarBalances", "causeJarOverflowCounts",
             "referredBy", "referralCount", "pushOptIn", "fcmTokens"
           ]);
      allow delete: if false;

      // ─── Skips ──────────────────────────────────────────────────────────
      // Written exclusively by the server (Admin SDK) via /api/skips so totals
      // computed from this subcollection (recalculate) can't be gamed by forged docs.
      match /skips/{skipId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      // ─── Donations ──────────────────────────────────────────────────────
      match /donations/{donationId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      // ─── Spending History ────────────────────────────────────────────────
      match /spendingHistory/{eventId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      // ─── Social Graph ────────────────────────────────────────────────────
      match /following/{targetUid} {
        // A user can see their own follow list; the followed user can verify
        // they're in the list for follower counts.
        allow read:   if isOwner(uid) || isOwner(targetUid);
        allow create: if isOwner(uid)
          && incomingData().uid == targetUid;
        allow delete: if isOwner(uid);
        allow update: if false;
      }
    }

    // ─── Projects (Causes) ──────────────────────────────────────────────────
    // Project data is public-facing content (challenge landing pages, share links).
    // Custom causes can only be edited / deleted by the user who created them;
    // built-in causes are read-only.
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isSignedIn()
        && incomingData().isCustom == true
        && incomingData().createdBy == request.auth.uid
        && incomingData().title is string
        && incomingData().title.size() > 0;
      // totalRaised and totalSkips are exclusively server-computed (Admin SDK writes via
      // /api/skips, /api/causes/*, /api/goals/* bypass these rules) — clients may no longer
      // touch them directly, closing the prior "any authenticated user can mutate any
      // project's totalRaised" gap.
      allow update: if isSignedIn()
        && !incomingData().diff(resource.data).affectedKeys().hasAny(["totalRaised", "totalSkips"])
        && (
          // Owner can edit their custom cause
          (resource.data.isCustom == true && resource.data.createdBy == request.auth.uid)
          ||
          // Any authenticated user can add only themselves to memberUids (join)
          (
            incomingData().diff(resource.data).affectedKeys().hasOnly(["memberUids"])
            && incomingData().memberUids is list
            && incomingData().memberUids.hasAll(resource.data.get("memberUids", []))
            && incomingData().memberUids.removeAll(resource.data.get("memberUids", [])).hasOnly([request.auth.uid])
            && incomingData().memberUids.size() == resource.data.get("memberUids", []).size() + 1
          )
          ||
          // Any authenticated user can remove only themselves from memberUids (leave)
          (
            incomingData().diff(resource.data).affectedKeys().hasOnly(["memberUids"])
            && incomingData().memberUids is list
            && resource.data.get("memberUids", []).hasAll(incomingData().memberUids)
            && resource.data.get("memberUids", []).removeAll(incomingData().memberUids).hasOnly([request.auth.uid])
            && incomingData().memberUids.size() == resource.data.get("memberUids", []).size() - 1
          )
        );
      allow delete: if isSignedIn()
        && resource.data.isCustom == true
        && resource.data.createdBy == request.auth.uid;
    }

    // ─── Personal Fan-out Feed ───────────────────────────────────────────────
    // The feed owner reads their own feed. Written exclusively by the server
    // (Admin SDK) as part of logging a skip.
    match /feed/{uid}/items/{itemId} {
      allow read: if isOwner(uid);
      allow create, update, delete: if false;
    }

    // ─── Community Feed ──────────────────────────────────────────────────────
    // All signed-in users can read. Written exclusively by the server (Admin SDK)
    // as part of the skip create/update/delete API routes.
    match /communityFeed/{skipId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // ─── Deny everything else ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
